# ══════════════════════════════════════════════
# 实体间关系
# ══════════════════════════════════════════════

# 控股关系（hasSubsidiary 由 isSubsidiaryOf 的反向推导，此处显式声明）
<urn:entity:group> ctio:hasSubsidiary <urn:entity:east_group> .
<urn:entity:group> ctio:hasSubsidiary <urn:entity:south_group> .
<urn:entity:group> ctio:hasSubsidiary <urn:entity:fin_group> .
<urn:entity:east_group> ctio:hasSubsidiary <urn:entity:sh_industry> .
<urn:entity:south_group> ctio:hasSubsidiary <urn:entity:gz_trade> .
<urn:entity:fin_group> ctio:hasSubsidiary <urn:entity:fin_co> .

# 资金归集关系
<urn:entity:east_group> ctio:fundFlowTo <urn:entity:group> .
<urn:entity:south_group> ctio:fundFlowTo <urn:entity:group> .
<urn:entity:fin_group> ctio:fundFlowTo <urn:entity:group> .
<urn:entity:sh_industry> ctio:fundFlowTo <urn:entity:east_group> .
<urn:entity:gz_trade> ctio:fundFlowTo <urn:entity:south_group> .
<urn:entity:fin_co> ctio:fundFlowTo <urn:entity:fin_group> .

# 担保关系
<urn:entity:group> ctio:guarantees <urn:entity:east_group> .
<urn:entity:east_group> ctio:guarantees <urn:entity:sh_industry> .

# ══════════════════════════════════════════════
# 监管指标数据（关联到实体）
# ══════════════════════════════════════════════

# 华东子集团的指标
<urn:indicator:east_f01> a ctio:RegulatoryIndicator ;
    ctio:indicatorId "f01" ;
    ctio:indicatorName "资金归集率" ;
    ctio:domain "资金集中" ;
    ctio:unit "%" ;
    ctio:currentValue 72.5 ;
    ctio:thresholdLow 85 ;
    ctio:thresholdHigh 95 ;
    ctio:direction "up" ;
    ctio:affectsEntity <urn:entity:east_group> .

<urn:indicator:east_d01> a ctio:RegulatoryIndicator ;
    ctio:indicatorId "d01" ;
    ctio:indicatorName "资产负债率" ;
    ctio:domain "债务融资" ;
    ctio:unit "%" ;
    ctio:currentValue 68.5 ;
    ctio:thresholdHigh 65 ;
    ctio:direction "down" ;
    ctio:affectsEntity <urn:entity:east_group> .

<urn:indicator:east_g01> a ctio:RegulatoryIndicator ;
    ctio:indicatorId "g01" ;
    ctio:indicatorName "风险事件数" ;
    ctio:domain "决策风险" ;
    ctio:unit "个" ;
    ctio:currentValue 8 ;
    ctio:thresholdHigh 5 ;
    ctio:direction "down" ;
    ctio:affectsEntity <urn:entity:east_group> .

# 华南子集团的指标（正常）
<urn:indicator:south_f01> a ctio:RegulatoryIndicator ;
    ctio:indicatorId "f01" ;
    ctio:indicatorName "资金归集率" ;
    ctio:domain "资金集中" ;
    ctio:unit "%" ;
    ctio:currentValue 92.4 ;
    ctio:thresholdLow 85 ;
    ctio:thresholdHigh 95 ;
    ctio:direction "up" ;
    ctio:affectsEntity <urn:entity:south_group> .

# 穿透路径数据（指标 → 实体 → 账户）
<urn:indicator:east_f01> ctio:affectedBy <urn:entity:east_group> .
<urn:entity:east_group> ctio:ownsAccount <urn:account:east_acct_001> .

<urn:account:east_acct_001> a ctio:DirectLinkedAccount ;
    ctio:accountNumber "ACC-EAST-001" ;
    ctio:balance 824000 ;
    ctio:status "active" ;
    ctio:isDirectLinked true .
